{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GameCapReaction",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GameCapReaction",
        "label": "main",
        "width": 600,
        "height": 140,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true
      },
      {
        "title": "Window Select",
        "label": "window-select",
        "width": 540,
        "height": 360,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "url": "/?window=select"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}